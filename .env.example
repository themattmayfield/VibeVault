# =============================================================================
# VibeVault (MoodSync) Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Convex (Real-time application database)
# https://dashboard.convex.dev
# -----------------------------------------------------------------------------
CONVEX_DEPLOYMENT=                # Deployment name, e.g. dev:moonlit-fox-464
VITE_CONVEX_URL=                  # Convex cloud URL, e.g. https://<name>.convex.cloud
VITE_CONVEX_SITE_URL=             # Convex site URL, e.g. https://<name>.convex.site

# -----------------------------------------------------------------------------
# Polar (Payments & Subscriptions)
# https://dashboard.polar.sh (prod) / https://sandbox.polar.sh (sandbox)
# -----------------------------------------------------------------------------
POLAR_ACCESS_TOKEN=               # Organization access token from Polar dashboard
POLAR_WEBHOOK_SECRET=             # Webhook verification secret
POLAR_SERVER=                     # "sandbox" for dev/preview, "production" for prod
POLAR_PRODUCT_ID=                 # (Legacy) Single product ID -- kept for backward compat
POLAR_PRO_MONTHLY_ID=             # Polar product ID for Pro Monthly plan
POLAR_PRO_ANNUAL_ID=              # Polar product ID for Pro Annual plan
POLAR_TEAM_MONTHLY_ID=            # Polar product ID for Team Monthly plan
POLAR_TEAM_ANNUAL_ID=             # Polar product ID for Team Annual plan
POLAR_ENTERPRISE_MONTHLY_ID=      # Polar product ID for Enterprise Monthly plan
POLAR_ENTERPRISE_ANNUAL_ID=       # Polar product ID for Enterprise Annual plan

# -----------------------------------------------------------------------------
# Anthropic (AI-powered mood insights)
# https://console.anthropic.com
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=                # Claude API key for generating patterns/triggers/suggestions

# -----------------------------------------------------------------------------
# Clerk (Authentication & User Management)
# https://dashboard.clerk.com
# -----------------------------------------------------------------------------
CLERK_PUBLISHABLE_KEY=            # Clerk publishable key (pk_test_... or pk_live_...)
CLERK_SECRET_KEY=                 # Clerk secret key (sk_test_... or sk_live_...)
VITE_CLERK_PUBLISHABLE_KEY=       # Same as CLERK_PUBLISHABLE_KEY (exposed to browser)
CLERK_FRONTEND_API_URL=           # Clerk Frontend API URL for Convex integration
                                  # Format: https://verb-noun-00.clerk.accounts.dev

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
VITE_APP_DOMAIN=                  # Base domain for UI display (e.g. moodsync.com). Used in URL
                                  # previews like "moodsync.com/org/{slug}". Not used for routing.

# -----------------------------------------------------------------------------
# Vercel Feature Flags
# -----------------------------------------------------------------------------
FLAGS_SECRET=                     # Secret for Vercel feature flag endpoint verification
                                  # Generate with: node -e "console.log(crypto.randomBytes(32).toString('base64url'))"

# -----------------------------------------------------------------------------
# Agent / CI Tooling (optional - for CLI-based automation)
# -----------------------------------------------------------------------------
# VERCEL_TOKEN=                   # Vercel personal access token for CLI deployments

# CONVEX_DEPLOY_KEY=              # Convex deploy key for CI/CD (npx convex deploy)
