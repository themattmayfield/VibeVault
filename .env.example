# =============================================================================
# VibeVault (MoodSync) Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Convex (Real-time application database)
# https://dashboard.convex.dev
# -----------------------------------------------------------------------------
CONVEX_DEPLOYMENT=                # Deployment name, e.g. dev:moonlit-fox-464
VITE_CONVEX_URL=                  # Convex cloud URL, e.g. https://<name>.convex.cloud
VITE_CONVEX_SITE_URL=             # Convex site URL, e.g. https://<name>.convex.site

# -----------------------------------------------------------------------------
# Neon PostgreSQL (Auth database via Better Auth + Drizzle ORM)
# https://console.neon.tech
# -----------------------------------------------------------------------------
DATABASE_URL=                     # Neon pooled connection string
                                  # Format: postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# -----------------------------------------------------------------------------
# Polar (Payments & Subscriptions)
# https://dashboard.polar.sh (prod) / https://sandbox.polar.sh (sandbox)
# -----------------------------------------------------------------------------
POLAR_ACCESS_TOKEN=               # Organization access token from Polar dashboard
POLAR_WEBHOOK_SECRET=             # Webhook verification secret

# -----------------------------------------------------------------------------
# Anthropic (AI-powered mood insights)
# https://console.anthropic.com
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=                # Claude API key for generating patterns/triggers/suggestions

# -----------------------------------------------------------------------------
# Resend (Email delivery)
# https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=                   # API key for sending verification emails

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
VITE_APP_DOMAIN=                  # Base domain for UI display (e.g. moodsync.com). Used in URL
                                  # previews like "moodsync.com/org/{slug}". Not used for routing.

# -----------------------------------------------------------------------------
# Agent / CI Tooling (optional - for CLI-based automation)
# -----------------------------------------------------------------------------
# VERCEL_TOKEN=                   # Vercel personal access token for CLI deployments
# NEON_API_KEY=                   # Neon API key for neonctl CLI operations
# CONVEX_DEPLOY_KEY=              # Convex deploy key for CI/CD (npx convex deploy)
